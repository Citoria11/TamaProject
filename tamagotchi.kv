<TamagotchiLayout>:
    orientation: 'vertical'
    padding: dp(14)
    spacing: dp(12)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: dp(170)
        spacing: dp(12)

        BoxLayout:
            orientation: 'vertical'
            padding: dp(16)
            canvas.before:
                Color:
                    rgba: 0.92, 0.95, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20]

            Label:
                id: pet_face
                text: "(◕‿◕)\n  ||  ||"
                font_size: '52sp'
                color: 0.1, 0.1, 0.2, 1
                halign: 'center'
                valign: 'middle'
                text_size: self.size

        BoxLayout:
            orientation: 'vertical'
            padding: dp(16)
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: 0.96, 0.96, 0.98, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20]

            Label:
                id: mood
                text: "Mood: Okay"
                font_size: '22sp'
                bold: True
                color: 0.1, 0.1, 0.2, 1
                size_hint_y: None
                height: self.texture_size[1]

            Label:
                id: level_text
                text: "Level 1\nAge 1"
                font_size: '16sp'
                color: 0.2, 0.2, 0.35, 1
                halign: 'left'
                valign: 'middle'
                text_size: self.width, None

            Label:
                id: current_status
                text: 'Ready to monitor the phone.'
                font_size: '15sp'
                color: 0.15, 0.15, 0.35, 1
                halign: 'left'
                valign: 'top'
                text_size: self.width, None

    BoxLayout:
        orientation: 'vertical'
        spacing: dp(10)
        padding: dp(12)
        canvas.before:
            Color:
                rgba: 0.97, 0.97, 0.99, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [20]

        GridLayout:
            cols: 2
            row_default_height: dp(76)
            spacing: dp(10)

            BoxLayout:
                orientation: 'vertical'
                spacing: dp(4)
                Label:
                    text: 'Energy'
                    font_size: '14sp'
                    color: 0.12, 0.12, 0.25, 1
                    size_hint_y: None
                    height: self.texture_size[1]
                ProgressBar:
                    id: energy_bar
                    max: 100
                    value: 70
                    size_hint_y: None
                    height: dp(16)
                Label:
                    id: energy_value
                    text: '70%'
                    font_size: '13sp'
                    color: 0.12, 0.12, 0.25, 1
                    size_hint_y: None
                    height: self.texture_size[1]

            BoxLayout:
                orientation: 'vertical'
                spacing: dp(4)
                Label:
                    text: 'Health'
                    font_size: '14sp'
                    color: 0.12, 0.12, 0.25, 1
                    size_hint_y: None
                    height: self.texture_size[1]
                ProgressBar:
                    id: health_bar
                    max: 100
                    value: 85
                    size_hint_y: None
                    height: dp(16)
                Label:
                    id: health_value
                    text: '85%'
                    font_size: '13sp'
                    color: 0.12, 0.12, 0.25, 1
                    size_hint_y: None
                    height: self.texture_size[1]

            BoxLayout:
                orientation: 'vertical'
                spacing: dp(4)
                Label:
                    text: 'Happiness'
                    font_size: '14sp'
                    color: 0.12, 0.12, 0.25, 1
                    size_hint_y: None
                    height: self.texture_size[1]
                ProgressBar:
                    id: happiness_bar
                    max: 100
                    value: 75
                    size_hint_y: None
                    height: dp(16)
                Label:
                    id: happiness_value
                    text: '75%'
                    font_size: '13sp'
                    color: 0.12, 0.12, 0.25, 1
                    size_hint_y: None
                    height: self.texture_size[1]

            BoxLayout:
                orientation: 'vertical'
                spacing: dp(4)
                Label:
                    text: 'Stress'
                    font_size: '14sp'
                    color: 0.12, 0.12, 0.25, 1
                    size_hint_y: None
                    height: self.texture_size[1]
                ProgressBar:
                    id: stress_bar
                    max: 100
                    value: 20
                    size_hint_y: None
                    height: dp(16)
                Label:
                    id: stress_value
                    text: '20%'
                    font_size: '13sp'
                    color: 0.12, 0.12, 0.25, 1
                    size_hint_y: None
                    height: self.texture_size[1]

    BoxLayout:
        orientation: 'vertical'
        spacing: dp(10)

        BoxLayout:
            spacing: dp(8)
            size_hint_y: None
            height: dp(48)

            Button:
                text: 'Purge'
                on_press: app.on_purge()
                background_color: 0.8, 0.4, 0.2, 1
                color: 1, 1, 1, 1
            Button:
                text: 'Cool Down'
                on_press: app.on_cool_down()
                background_color: 0.2, 0.6, 0.9, 1
                color: 1, 1, 1, 1
            Button:
                text: 'Decongest'
                on_press: app.on_decongest()
                background_color: 0.3, 0.7, 0.4, 1
                color: 1, 1, 1, 1
            Button:
                text: 'Diagnose'
                on_press: app.on_diagnose()
                background_color: 0.55, 0.55, 0.9, 1
                color: 1, 1, 1, 1

        BoxLayout:
            orientation: 'vertical'
            padding: dp(12)
            canvas.before:
                Color:
                    rgba: 0.94, 0.94, 0.96, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [16]

            Label:
                text: 'Phone Status'
                font_size: '16sp'
                bold: True
                color: 0.12, 0.12, 0.25, 1
                size_hint_y: None
                height: self.texture_size[1]

            GridLayout:
                cols: 2
                row_default_height: dp(26)
                spacing: dp(8)

                Label:
                    text: 'Battery:'
                    color: 0.15, 0.15, 0.35, 1
                Label:
                    id: battery_value
                    text: 'N/A'
                    color: 0.15, 0.15, 0.35, 1

                Label:
                    text: 'Charging:'
                    color: 0.15, 0.15, 0.35, 1
                Label:
                    id: charge_value
                    text: 'No'
                    color: 0.15, 0.15, 0.35, 1

                Label:
                    text: 'CPU:'
                    color: 0.15, 0.15, 0.35, 1
                Label:
                    id: cpu_value
                    text: 'N/A'
                    color: 0.15, 0.15, 0.35, 1

                Label:
                    text: 'Memory:'
                    color: 0.15, 0.15, 0.35, 1
                Label:
                    id: memory_value
                    text: 'N/A'
                    color: 0.15, 0.15, 0.35, 1

                Label:
                    text: 'Network:'
                    color: 0.15, 0.15, 0.35, 1
                Label:
                    id: network_value
                    text: 'Offline'
                    color: 0.15, 0.15, 0.35, 1

                Label:
                    text: 'Latency:'
                    color: 0.15, 0.15, 0.35, 1
                Label:
                    id: network_latency
                    text: 'N/A'
                    color: 0.15, 0.15, 0.35, 1

        Label:
            id: device_status
            text: 'Device status will appear here.'
            font_size: '15sp'
            size_hint_y: None
            height: self.texture_size[1]
            color: 0.15, 0.15, 0.35, 1
            halign: 'center'
            text_size: self.width, None
